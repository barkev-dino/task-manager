# ─── Supabase ────────────────────────────────────────────────────────────────
# Your Supabase project URL (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon / publishable key (safe for browser)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Service role key — SERVER SIDE ONLY. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Optional: LLM extractor ─────────────────────────────────────────────────
# Leave blank to use the deterministic mock extractor (default for v1)
OPENAI_API_KEY=

# ─── Extractor mode ──────────────────────────────────────────────────────────
# "mock" (default) or "openai" (requires OPENAI_API_KEY)
EXTRACTOR=mock
